# ============================================================
# Quiz Master - environment template
# Copy to .env and edit values before deploying.
# ============================================================

# ---- Database (required) ------------------------------------
DB_USER=quiz_user
DB_PASSWORD=change_me_to_something_strong
DB_NAME=quiz_master

# ---- Admin authentication (required) ------------------------
# Password used to sign in to the Admin Dashboard.
ADMIN_PASSWORD=admin

# Signs JWT auth tokens. MUST be long and random in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# ---- Node environment ---------------------------------------
NODE_ENV=production

# ---- Optional: host port overrides --------------------------
# Uncomment to bind a different host port to each frontend.
# (Internal container ports are always 80.)
# ADMIN_PORT=3001
# SLIDESHOW_PORT=3002
# QUIZZER_PORT=3003

# ---- Optional: custom domain URLs ---------------------------
# Public URLs for each portal. These drive the join links + on-screen address
# labels shown on the Admin Control page and the Slideshow lobby. They are
# passed to the backend and served from GET /api/config (fetched at runtime —
# nothing is baked into the frontend build).
#
#   * Set the full external URL, no trailing slash needed.
#   * The quizzer link becomes a path deep-link: https://answer.website.com/<CODE>
#   * Leave unset for the port-based fallback (localhost:3001/3002/3003).
#   * After changing these, recreate the backend: docker-compose up -d
# ADMIN_URL=https://admin.website.com
# SLIDESHOW_URL=https://show.website.com
# QUIZZER_URL=https://answer.website.com
