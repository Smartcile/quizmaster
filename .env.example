# ============================================================
# Quiz Master - environment template
# Copy to .env and edit values before deploying.
# ============================================================

# ---- Database (required) ------------------------------------
DB_USER=quiz_user
DB_PASSWORD=change_me_to_something_strong
DB_NAME=quiz_master

# ---- Admin authentication (required) ------------------------
# Password used to sign in to the Admin Dashboard.
ADMIN_PASSWORD=admin

# Signs JWT auth tokens. MUST be long and random in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# ---- Node environment ---------------------------------------
NODE_ENV=production

# ---- Optional: host port overrides --------------------------
# Uncomment to bind a different host port to each frontend.
# (Internal container ports are always 80.)
# ADMIN_PORT=3001
# SLIDESHOW_PORT=3002
# QUIZZER_PORT=3003

# ---- Optional: custom domain URLs ---------------------------
# When set, these override the automatic port-replacement fallback used by the
# Admin Dashboard to display the quizzer / slideshow join URL in the lobby.
# Set these if your portals are served on different hostnames (e.g. Cloudflare).
# Leave unset for the default port-based fallback (localhost:3001/3002/3003).
# ADMIN_URL=https://quiz.example.com
# SLIDESHOW_URL=https://show.example.com
# QUIZZER_URL=https://answer.example.com
