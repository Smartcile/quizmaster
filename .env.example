# Database credentials
DB_USER=quiz_user
DB_PASSWORD=quiz_password
DB_NAME=quiz_master

# Admin login password (used to sign in to the Admin Dashboard)
ADMIN_PASSWORD=admin

# JWT signing secret - CHANGE THIS in production!
JWT_SECRET=change-me-in-production

# Node environment
NODE_ENV=production

# Optional: override host ports (defaults 3001/3002/3003)
# ADMIN_PORT=3001
# SLIDESHOW_PORT=3002
# QUIZZER_PORT=3003
